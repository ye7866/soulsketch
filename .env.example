# ── OpenAI (optional — for AI readings + DALL-E portraits) ──
OPENAI_API_KEY=sk-your-key-here

# ── LemonSqueezy (payment) ──
# 1. Go to app.lemonsqueezy.com → Settings → Webhooks
# 2. Add endpoint: https://yourdomain.com/api/webhook
# 3. Copy the signing secret below
LEMONSQUEEZY_WEBHOOK_SECRET=your-webhook-signing-secret

# ── App Config ──
BASE_URL=http://localhost:3000
PORT=3000
