# 2. Settings → Advanced → Webhook URL: https://yourdomain.com/api/webhook
# 3. Copy the webhook signing secret below (optional, for verification)
GUMROAD_WEBHOOK_SECRET=

# ── App Config ──
BASE_URL=http://localhost:3000
PORT=3000
